APP_NAME=Nyaya AI Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
MAX_UPLOAD_MB=15
TESSERACT_CMD=
ENABLE_IMAGE_OCR=true
ENABLE_PDF_OCR=false
DEFAULT_LANGUAGE=en

# AI Layer Configuration
