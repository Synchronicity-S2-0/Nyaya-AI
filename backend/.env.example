GEMINI_API_KEY=
SARVAM_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=case-documents
LOCAL_KNOWLEDGE_PATH=app/data/legal_knowledge.txt
